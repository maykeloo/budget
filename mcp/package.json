{
  "name": "mcp",
  "version": "1.0.0",
  "description": "MCP TypeScript project",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest --watch=false",
    "inspect:dev": "DANGEROUSLY_OMIT_AUTH=true && npx @modelcontextprotocol/inspector npm run dev"
  },
  "dependencies": {
    "@modelcontextprotocol/inspector": "^0.16.2",
    "@modelcontextprotocol/sdk": "^1.17.0",
    "express": "^5.1.0",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
